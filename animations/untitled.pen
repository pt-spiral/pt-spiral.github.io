                      "content": "Requirements",
                      "fontFamily": "EB Garamond",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "kgX64",
                      "name": "reqList",
                      "fill": "$burgundy-80",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "•  Currently enrolled in or recently graduated from a relevant program\n•  Strong written and verbal communication skills\n•  Interest in sustainability, e-commerce, or social impact\n•  Ability to manage multiple tasks in a fast-paced environment\n•  Proficiency in Google Workspace or similar tools\n•  Based in or willing to relocate to New York City",
                      "lineHeight": 1.8,
                      "fontFamily": "EB Garamond",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
